{
  "name": "spacetrack-frontend",
  "version": "1.0.0",
  "description": "SpaceTrack UI — Express + TypeScript",
  "scripts": {
    "dev:client": "esbuild src/client/main.ts --bundle --outfile=public/js/bundle.js --platform=browser --watch",
    "dev:server": "nodemon --watch app.ts --watch routes --watch services --ext ts --exec \"ts-node app.ts\"",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build:client": "esbuild src/client/main.ts --bundle --outfile=public/js/bundle.js --platform=browser --minify",
    "build:server": "tsc",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/app.js"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "ejs": "^3.1.10",
    "express": "^4.19.0",
    "globe.gl": "^2.31.0",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20.14.0",
    "@types/three": "^0.164.0",
    "concurrently": "^8.2.0",
    "esbuild": "^0.21.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
