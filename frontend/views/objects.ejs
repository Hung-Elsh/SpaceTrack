<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SpaceTrack — Tracking Object</title>

  <!-- Bootstrap 5 -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

  <!-- Custom theme (loaded after Bootstrap so it takes precedence) -->
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="data-page">

<div id="app">

  <%- include('partials/header') %>

  <main id="data-view">
    <section class="pull-panel">
      <div class="pull-card">
        <div class="pull-card-header">
          <h2>tracked_objects</h2>
          <button id="btn-pull-objects" class="btn btn-primary btn-pull" disabled>Pull data</button>
        </div>
        <p class="pull-status" id="status-objects">Checking availability…</p>
      </div>
    </section>

    <section class="tree-panel">
      <div class="tree-card">
        <div class="tree-card-header">
          <h3>tracked_objects</h3>
          <span class="tree-hint">Filter / group by — coming soon</span>
        </div>
        <div id="tree-objects" class="tree-view"><p class="tree-empty">Loading…</p></div>
      </div>
    </section>
  </main>

</div>

<!-- Bootstrap JS bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<!-- Client bundle (esbuild output) -->
<script src="/js/objects.js"></script>

</body>
</html>
