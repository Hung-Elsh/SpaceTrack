<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SpaceTrack</title>

  <!-- Bootstrap 5 -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

  <!-- Leaflet CSS -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <!-- Custom theme (loaded after Bootstrap so it takes precedence) -->
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

<div id="app">

  <%- include('partials/header') %>

  <div id="view-container">
    <div id="globe-view"></div>
    <div id="map-view" class="hidden"></div>

    <%- include('partials/sidebar') %>

    <div id="legend">
      <div class="legend-title">Orbit type</div>
      <div class="legend-item"><span class="dot leo"></span>LEO (&lt; 2,000 km)</div>
      <div class="legend-item"><span class="dot meo"></span>MEO (2,000 – 35,786 km)</div>
      <div class="legend-item"><span class="dot geo"></span>GEO (35,786 km)</div>
      <div class="legend-item"><span class="dot heo"></span>HEO (elliptical)</div>
    </div>
  </div>

</div>

<!-- Bootstrap JS bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<!-- Client bundle (esbuild output) -->
<script src="/js/bundle.js"></script>

</body>
</html>
